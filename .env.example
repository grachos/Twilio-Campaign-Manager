# ============================================================
# Twilio Campaign Manager — Configuration File
# ============================================================
# Copy this file to .env and fill in your credentials.
# The .env file must be in the same folder as the .exe (or project root).
# ============================================================

# --- Twilio Credentials ---
# Find these in your Twilio Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Messaging (optional) ---
# Leave empty to send directly from the DEFAULT_SENDER number
TWILIO_MESSAGING_SERVICE_SID=

# --- Default Sender (WhatsApp) ---
# The WhatsApp number that messages will be sent FROM
# Required when no Messaging Service SID is set
TWILIO_DEFAULT_SENDER=whatsapp:+573103728894

# --- Status Callback (optional) ---
# URL where Twilio sends delivery status updates
STATUS_CALLBACK_URL=

# --- Performance Tuning ---
RETRY_ATTEMPTS=3
DELAY_BETWEEN_MSGS=0.5
MAX_PARALLEL_WORKERS=5
